generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Manager {
  id           String        @id
  email        String?       @unique
  phone        String?       @unique
  name         String?
  isVerified   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  restaurant   Restaurant?
  subscription Subscription?
}

model Restaurant {
  id          String        @id @default(cuid())
  name        String
  ownerName   String
  city        String
  address     String
  logoUrl     String?
  upiId       String
  themeColor  String        @default("#000000")
  managerId   String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  categories  Category[]
  manager     Manager       @relation(fields: [managerId], references: [id])
  tables      Table[]
  orders      Order[]
  waiterCalls WaiterCall[]
}

model Category {
  id           String     @id @default(cuid())
  name         String
  restaurantId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]

  @@index([restaurantId])
}

model MenuItem {
  id              String      @id @default(cuid())
  name            String
  price           Decimal
  costPrice       Decimal?    // Cost of goods sold — used for margin analytics
  type            String
  imageUrl        String?
  isAvailable     Boolean     @default(true)
  isDeleted       Boolean     @default(false)
  prepTimeMinutes Int?        // Estimated prep time in minutes e.g. 12
  categoryId      String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  category        Category    @relation(fields: [categoryId], references: [id])
  orderItems      OrderItem[]

  @@index([categoryId])
  @@index([isDeleted])
  @@index([categoryId, isDeleted])
}

model Table {
  id           String     @id @default(cuid())
  tableNumber  String
  qrCodeUrl    String?
  restaurantId String
  isOccupied   Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  orders       Order[]
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

model Order {
  id               String      @id @default(cuid())
  tableId          String
  restaurantId     String
  totalAmount      Decimal
  status           String
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  transactionId    String?
  paymentSessionId String?
  paymentStatus    String      @default("pending")
  paymentMethod    String      @default("ONLINE")
  customerPhone    String?     // Optional WhatsApp number for notification
  table            Table       @relation(fields: [tableId], references: [id])
  restaurant       Restaurant  @relation(fields: [restaurantId], references: [id])
  orderItems       OrderItem[]

  @@index([tableId])
  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
  @@index([restaurantId, status, createdAt])
  @@index([restaurantId, customerPhone, createdAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int
  subtotal   Decimal
  notes      String?  // Optional special instructions (max 80 chars) e.g. "Extra spicy, no onions"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([menuItemId])
}

model AuditLog {
  id         String   @id @default(cuid())
  managerId  String
  action     String   // e.g., "UPDATE_UPI", "CREATE_ITEM", "DELETE_TABLE"
  resource   String   // e.g., "Restaurant", "MenuItem", "Table"
  resourceId String?
  details    Json?    // Specific changes (e.g., old vs new UPI)
  timestamp  DateTime @default(now())

  @@index([managerId])
  @@index([timestamp])
}

model WaiterCall {
  id             String     @id @default(cuid())
  restaurantId   String
  tableNumber    String
  isAcknowledged Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([isAcknowledged])
}

model Subscription {
  id                   String   @id @default(cuid())
  managerId            String   @unique
  status               String   @default("INACTIVE") // ACTIVE, INACTIVE, PAST_DUE, CANCELED
  planId               String   @default("MONTHLY_1499")
  currentPeriodStart   DateTime @default(now())
  currentPeriodEnd     DateTime
  cashfreeSubscriptionId String? @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  manager              Manager  @relation(fields: [managerId], references: [id])

  @@index([managerId])
}
